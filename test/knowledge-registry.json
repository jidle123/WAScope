{
  "id": "digital-trace-knowledge-registry",
  "version": "0.1.0",
  "description": "External knowledge pack registry for the local Digital Trace MVP.",
  "storage_contract": {
    "seed_packs": "Versioned JSON files under data/knowledge.",
    "runtime_overlay": "Browser localStorage keeps learned case memory, human corrections, and customer-private additions.",
    "future_storage": "SQLite/Postgres node-edge tables before any graph database is introduced."
  },
